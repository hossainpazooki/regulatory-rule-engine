# Frontend environment — copy to `.env.local` for local overrides.
# `.env.example` is documentation only; Vite does not load it. Committing it
# keeps the recognized VITE_* keys discoverable without shipping any live value.
#
# DEFAULT BEHAVIOR (no .env.local, or this file's values): every Gate-5 flag is
# OFF and the app behaves exactly as `main` — all pages fetch via VITE_API_URL.

# --- Fallback backend (the untouched, always-available data source) ---
# When unset, the app uses '/api' (dev proxy). Leave this as your only data
# source unless you are intentionally exercising a Gate-5 local surface.
# VITE_API_URL=http://localhost:8000

# --- Gate-5 feature flags (spec § 7.4). ALL DEFAULT-OFF. ---
# A flag is ON only for the exact string "true" (case-insensitive). Anything
# else — including "false", "0", "1", "" or leaving it unset — is OFF.

# Route a page's REST call to `ke-cli serve` instead of VITE_API_URL.
VITE_USE_LOCAL_KE_API=false

# Use the frontend/src/wasm adapter for compile-preview / dry-run.
VITE_USE_WASM_PREVIEW=false

# Show the 5e AI-provenance review UI.
VITE_USE_REVIEW_UI=false

# Base URL for the local ke-cli serve surface. Used ONLY when a local variant
# is active (default below). Non-authoritative preview/verify surface only.
# VITE_KE_SERVE_URL=http://localhost:8787
